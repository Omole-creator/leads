// JobMingle Cohort Lead Tracking System — Prisma schema
// See plan: amountPaid defaults to 0 at ingest (form has no payment field);
// startTimeline is captured from the form and mapped to a find-or-created Cohort.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (Supabase pgbouncer, port 6543) at runtime
  directUrl = env("DIRECT_URL")   // direct (port 5432) for migrations
}

enum Role {
  ADMIN
  SALES_REP
  TUTOR
}

enum Stage {
  NEW
  CALLED
  CLOSED_WON
  CLOSED_LOST
  NO_ANSWER
  SILENT
}

enum FollowUpType {
  INITIAL_CALL
  WHATSAPP
  PRICING_SENT
  PAYMENT_LINK
  PAYMENT_CONFIRMED
  FINAL_FOLLOWUP
  ONBOARDING
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  role           Role     @default(SALES_REP)
  active         Boolean  @default(true)
  lastAssignedAt DateTime?
  createdAt      DateTime @default(now())

  assignedLeads  Lead[]          @relation("AssignedRep")
  notes          Note[]
  activityLog    ActivityLog[]
  followUpsDone  FollowUp[]
  followUpLogs   FollowUpLog[]
  emailCampaigns EmailCampaign[]
  tracksTutored  Track[]         @relation("TrackTutor")
  attendanceTaken Attendance[]
}

// A record of each bulk email sent, so admins can revisit past sends.
model EmailCampaign {
  id         String   @id @default(uuid())
  status     String   @default("SENT") // DRAFT | SENT
  subject    String
  body       String
  segment    String?
  trackId    String?
  stage      String?
  cohortId   String?
  recipients Int      @default(0)
  sent       Int      @default(0)
  failed     Int      @default(0)
  sentById   String?
  createdAt  DateTime @default(now())

  sentBy User? @relation(fields: [sentById], references: [id])
}

model Cohort {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  leads Lead[]
}

model Track {
  id      String  @id @default(uuid())
  name    String  @unique
  cost    Decimal @db.Decimal(12, 2)
  active  Boolean @default(true)
  tutorId String?

  tutor        User?        @relation("TrackTutor", fields: [tutorId], references: [id])
  leads        Lead[]       @relation("LeadInterestTrack")
  studentLeads Lead[]       @relation("LeadStudentTrack")
  attendance   Attendance[]
}

// One attendance mark per student (won lead) per class date.
model Attendance {
  id        String   @id @default(uuid())
  leadId    String
  trackId   String
  date      DateTime
  present   Boolean
  byId      String?
  createdAt DateTime @default(now())

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id])
  by    User? @relation(fields: [byId], references: [id])

  @@unique([leadId, date])
  @@index([trackId])
}

model Lead {
  id             String   @id @default(uuid())
  fullName       String
  email          String
  phone          String
  trackId        String
  amountPaid     Decimal  @default(0) @db.Decimal(12, 2)
  balanceLeft    Decimal  @db.Decimal(12, 2)
  howFoundUs     String
  segment        String   @default("APPLICATION") // APPLICATION | SCHOLARSHIP | IMPORTED | ...
  startTimeline  String
  cohortId       String
  assignedRepId  String?
  stage          Stage    @default(NEW)
  closedAt       DateTime?
  studentStatus  String   @default("ACTIVE") // ACTIVE | DROPPED | DEFERRED | COMPLETED
  studentTrackId String?  // track used for tutoring/attendance (set when won)
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())

  track        Track         @relation("LeadInterestTrack", fields: [trackId], references: [id])
  studentTrack Track?        @relation("LeadStudentTrack", fields: [studentTrackId], references: [id])
  cohort       Cohort        @relation(fields: [cohortId], references: [id])
  assignedRep  User?         @relation("AssignedRep", fields: [assignedRepId], references: [id])
  attendance   Attendance[]
  followUps    FollowUp[]
  followUpLogs FollowUpLog[]
  notes        Note[]
  activityLog  ActivityLog[]

  @@index([cohortId])
  @@index([assignedRepId])
  @@index([stage])
}

// One row per follow-up attempt a closer logs (tap "Reached" / "No answer").
model FollowUpLog {
  id        String   @id @default(uuid())
  leadId    String
  byId      String?
  reached   Boolean  @default(false)
  createdAt DateTime @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  by   User? @relation(fields: [byId], references: [id])

  @@index([leadId])
}

model FollowUp {
  id            String       @id @default(uuid())
  leadId        String
  type          FollowUpType
  done          Boolean      @default(false)
  completedAt   DateTime?
  completedById String?

  lead        Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  completedBy User? @relation(fields: [completedById], references: [id])

  @@unique([leadId, type])
}

model Note {
  id        String   @id @default(uuid())
  leadId    String
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  lead   Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id])
}

model ActivityLog {
  id        String   @id @default(uuid())
  leadId    String
  userId    String?
  action    String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([leadId])
}
