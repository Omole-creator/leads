# --- Database (Supabase / Neon PostgreSQL) ---
# Supabase: copy from Project Settings → Database → Connection string.
#   DATABASE_URL = "Transaction pooler" URI (port 6543) + ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = "Direct connection" URI (port 5432) — used only for migrations
# To share one Supabase project with another app, add &schema=jobmingle to isolate tables.
DATABASE_URL="postgresql://postgres.ref:pass@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.ref:pass@aws-region.pooler.supabase.com:5432/postgres"
DATABASE_URL_TEST="postgresql://postgres.ref:pass@aws-region.pooler.supabase.com:5432/postgres?schema=jobmingle_test"

# --- Auth (NextAuth / Auth.js v5) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_SECRET="same-as-NEXTAUTH_SECRET"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Email (Resend) ---
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="leads@jobmingle.com"

# --- Ingestion bridge ---
INGEST_SHARED_SECRET="long-random-string-shared-with-gmail-bridge"

# --- App ---
APP_URL="http://localhost:3000"
